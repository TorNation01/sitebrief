# ─── SiteBrief — copy to `.env.local` (local) or your host’s env UI (production)
# ─── Never commit secrets; only NEXT_PUBLIC_* and contact email belong in shared samples.

# Public site origin (recommended). Canonical base for Metadata / Open Graph.
# Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# ─── Brand (white-label) — all NEXT_PUBLIC_* are baked at build time
# Product label (marketing header, metadata, prompts, exports when untitled elsewhere)
NEXT_PUBLIC_SITEBRIEF_APP_NAME=SiteBrief
# Sidebar / login operating name — your agency or company
NEXT_PUBLIC_SITEBRIEF_STUDIO_DISPLAY_NAME=Your studio
# Optional: absolute URL (https…) or `/path-in-public-folder.svg`. Leave blank for pillar mark.
NEXT_PUBLIC_SITEBRIEF_LOGO_URL=
# Optional alias for tooling that prefers `_SRC`:
# NEXT_PUBLIC_SITEBRIEF_LOGO_SRC=

# Accent as #RRGGBB (derive hover automatically) or supply both explicitly
NEXT_PUBLIC_SITEBRIEF_ACCENT=#c9a962
# NEXT_PUBLIC_SITEBRIEF_ACCENT_HOVER=

# Footer one-liner · optional override of default tagline
# NEXT_PUBLIC_SITEBRIEF_SITE_TAGLINE=

# Open Graph default description · optional override
# NEXT_PUBLIC_SITEBRIEF_META_DESCRIPTION=

# Slug for downloaded prompt filenames (letters/digits only, max 32)
# NEXT_PUBLIC_SITEBRIEF_EXPORT_SLUG=sitebrief

# ─── Core Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Future: notifications pipeline (transactional inbox; server-side only — do not prefix NEXT_PUBLIC_)
SITEBRIEF_NOTIFICATION_EMAIL=

# Optional server-only escalation — never NEXT_PUBLIC_
# SUPABASE_SERVICE_ROLE_KEY=
