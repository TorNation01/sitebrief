# ─── SiteBrief — copy to `.env.local` (local) or your host env UI (production)
# ─── Never commit secrets; only NEXT_PUBLIC_* and notification email belong in samples.

# Canonical public origin (required for metadata / Open Graph absolutes).
# Production (Anakatech): https://sitebrief.anakatech.llc
# Local development: override in `.env.local` as NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://sitebrief.anakatech.llc

# Primary product label and operating org (mapped in src/lib/sitebrief/brand.ts).
# Optional NEXT_PUBLIC_SITEBRIEF_* keys override these when set — see README.
NEXT_PUBLIC_APP_NAME=SiteBrief
NEXT_PUBLIC_BRAND_OWNER=Anakatech

# ─── Optional white-label (takes precedence over APP_NAME / BRAND_OWNER when set)
NEXT_PUBLIC_SITEBRIEF_APP_NAME=SiteBrief
NEXT_PUBLIC_SITEBRIEF_STUDIO_DISPLAY_NAME=Anakatech

# NEXT_PUBLIC_SITEBRIEF_LOGO_URL=
# NEXT_PUBLIC_SITEBRIEF_LOGO_SRC=

# Accent as #RRGGBB (derive hover automatically) or supply both explicitly
NEXT_PUBLIC_SITEBRIEF_ACCENT=#c9a962
# NEXT_PUBLIC_SITEBRIEF_ACCENT_HOVER=

# NEXT_PUBLIC_SITEBRIEF_SITE_TAGLINE=
# NEXT_PUBLIC_SITEBRIEF_META_DESCRIPTION=
# NEXT_PUBLIC_SITEBRIEF_EXPORT_SLUG=sitebrief

# ─── Core Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Resend (https://resend.com) — intake notification emails (server-only)
RESEND_API_KEY=
# Verified sender identity, e.g. SiteBrief <briefs@yourdomain.com>
# For Resend quickstart you can use: SiteBrief <onboarding@resend.dev>
RESEND_FROM=

# Inbox(es) for new intake alerts — comma or semicolon separated
SITEBRIEF_NOTIFICATION_EMAIL=

# Set to false to skip the client "we received your brief" message
# SITEBRIEF_SEND_CLIENT_CONFIRMATION=true

# Optional server-only — never NEXT_PUBLIC_
# SUPABASE_SERVICE_ROLE_KEY=
